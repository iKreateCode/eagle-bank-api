              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated Doe\",\n  \"phoneNumber\": \"+447911999888\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "{{userId}}"]
            },
            "description": "Partially updates the user. All fields are optional: `name`, `email`, `phoneNumber`, `address`."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "PATCH",
                "header": [
                  {"key": "Authorization", "value": "Bearer {{token}}"},
                  {"key": "Content-Type", "value": "application/json"}
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"John Updated Doe\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["v1", "users", "{{userId}}"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [],
              "body": "{\n  \"id\": \"usr-abc123\",\n  \"name\": \"John Updated Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phoneNumber\": \"+447911999888\",\n  \"address\": {\n    \"line1\": \"123 High Street\",\n    \"town\": \"London\",\n    \"county\": \"Greater London\",\n    \"postcode\": \"EC1A 1BB\"\n  },\n  \"createdTimestamp\": \"2026-01-01T00:00:00.000Z\",\n  \"updatedTimestamp\": \"2026-01-01T12:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "users", "{{userId}}"]
            },
            "description": "Deletes the user. Returns 409 if the user still has bank accounts open."
          },
          "response": [
            {
              "name": "204 No Content",
              "originalRequest": {
                "method": "DELETE",
                "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
                "url": {
                  "raw": "{{baseUrl}}/v1/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["v1", "users", "{{userId}}"]
                }
              },
              "status": "No Content",
              "code": 204,
              "_postman_previewlanguage": "text",
              "header": [],
              "body": ""
            },
            {
              "name": "409 Has Accounts",
              "originalRequest": {
                "method": "DELETE",
                "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
                "url": {
                  "raw": "{{baseUrl}}/v1/users/{{userId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["v1", "users", "{{userId}}"]
                }
              },
              "status": "Conflict",
              "code": 409,
              "_postman_previewlanguage": "json",
              "header": [],
              "body": "{\n  \"message\": \"User cannot be deleted while they have bank accounts\"\n}"
            }
          ]
        }
      ]
    },
